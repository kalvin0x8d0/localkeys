# ==========================================
# localkeys - Environment Configuration
# ==========================================

# --- Host Exposure Ports ---
# Change these if you have conflicts on your local machine.
# These dictate how you access the services from your browser/host.
FRONTEND_PORT=3000
BACKEND_PORT=8000
MONGODB_PORT=27017

# --- MongoDB Configuration ---
# Internal connection string for the backend to talk to the DB container.
MONGO_URL=mongodb://admin:password@mongodb:27017/localkeys?authSource=admin
DB_NAME=localkeys

# --- Backend Server Configuration ---
# Internal bind settings inside the container (do not change these).
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Security & CORS ---
# Comma-separated list of allowed frontend origins.
# IMPORTANT: If you change FRONTEND_PORT above, update the ports here!
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend Application Settings ---
# The URL where the frontend expects to find the backend API.
# IMPORTANT: If you change BACKEND_PORT above, update the port here!
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENV=development

# --- Site Metadata ---
SITE_NAME="LocalKeys"
SITE_DESCRIPTION="A zero-knowledge cryptographic key generator. Generate Nostr, JWT, SSH, and Argon2id keys entirely in your browser."
SITE_URL="https://start.duckduckgo.com/"
